generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------
enum Role {
  FAN
  CREATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  SHADOWBANNED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED 
}

enum TransactionType {
  SUBSCRIPTION
  TIP
  PPV_POST
  PPV_MESSAGE
  BUNDLE
  LIVE_TICKET 
  PAYOUT 
  PROMOTION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING 
  APPROVED
  REJECTED
  PAID
}

enum PostVisibility {
  PUBLIC
  SUBSCRIBERS_ONLY
}

enum MediaType {
  TEXT
  IMAGE
  VIDEO
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum KycStatus {
  NONE 
  PENDING 
  APPROVED 
  REJECTED 
}

enum PromoPackage {
  BASIC
  PRO
  GOD
}

// ------------------------------------------------------
// MODELOS
// ------------------------------------------------------

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  username         String?    @unique
  passwordHash     String
  name             String?
  role             Role       @default(FAN)
  status           UserStatus @default(ACTIVE)

  emailNotifications Boolean @default(true)
  pushNotifications  Boolean @default(true)
  isPrivateProfile   Boolean @default(false)
  isEmailVerified    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallet    Wallet?
  creatorProfile CreatorProfile?
  
  posts     Post[]
  comments  Comment[]
  likes     Like[]
  commentLikes CommentLike[] @relation("UserCommentLikes")

  subscriptions        Subscription[]    @relation("FanSubscriptions")
  subscribers          Subscription[]    @relation("CreatorSubscribers")
  sentTransactions     Transaction[]     @relation("SentTransactions")
  receivedTransactions Transaction[]     @relation("ReceivedTransactions")
  withdrawals          Withdrawal[]      @relation("CreatorWithdrawals")
  postPurchases        PostPurchase[]    @relation("FanPostPurchases")
  messagePurchases     MessagePurchase[] @relation("FanMessagePurchases")
  bundles              Bundle[]          @relation("CreatorBundles")
  bundlePurchases      BundlePurchase[]  @relation("FanBundlePurchases")
  discounts            Discount[]        @relation("CreatorDiscounts")
  coupons              Coupon[]          @relation("CreatorCoupons")

  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  creatorChats     Conversation[] @relation("CreatorConversations")
  fanChats         Conversation[] @relation("FanConversations")

  notifications    Notification[] @relation("UserNotifications")
  followers        Follow[]       @relation("Following")
  following        Follow[]       @relation("Followers")
  bookmarks        Bookmark[]
  promotions       Promotion[]    @relation("CreatorPromotions")
}

model Wallet {
  id              String @id @default(uuid())
  userId          String @unique
  balance         Float  @default(0.0) 
  pendingBalance  Float  @default(0.0) 
  cryptoAddress   String? 
  cryptoNetwork   String? 
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id              String            @id @default(uuid())
  senderId        String
  receiverId      String
  type            TransactionType
  status          TransactionStatus @default(PENDING)

  amount          Float 
  platformFee     Float 
  netAmount       Float 

  postId          String?
  attachedMessage String?
  bundleId        String?

  // 🛡️ Bóveda PayRam
  payramReceiptId String? @unique 
  payAddress      String? 

  createdAt       DateTime @default(now())
  sender          User     @relation("SentTransactions", fields: [senderId], references: [id], onDelete: Cascade)
  receiver        User     @relation("ReceivedTransactions", fields: [receiverId], references: [id], onDelete: Cascade)
}

// ... (Incluye aquí tus modelos restantes: Post, Subscription, CreatorProfile, etc. tal como los tenías)